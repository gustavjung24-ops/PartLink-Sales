{
  "name": "sparelink",
  "version": "1.0.0",
  "description": "SPARELINK - Offline-first desktop application for spare parts sales",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --recursive dev",
    "build": "pnpm --filter @sparelink/shared build && pnpm -r --filter './apps/*' build",
    "build:desktop-installer": "node ./scripts/build-installer.js",
    "test": "pnpm --recursive test",
    "lint": "pnpm --recursive lint",
    "type-check": "pnpm --filter @sparelink/shared type-check && pnpm -r --filter './apps/*' type-check",
    "postinstall": "pnpm --recursive exec -- node -e \"console.log('Installed')\""
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "keywords": [
    "sparelink",
    "partlink",
    "offline-first",
    "electron",
    "react",
    "typescript"
  ],
  "author": "PartLink Team",
  "license": "MIT"
}
