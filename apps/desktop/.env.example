# ============================================================================
# Desktop Build — Code Signing Environment Variables
# Copy this file to .env (git-ignored) for local signed builds.
# In CI, set these as GitHub Actions Secrets.
# ============================================================================

# ----------------------------------------------------------------------------
# Windows EV Code Signing (DigiCert / Sectigo / GlobalSign)
# ----------------------------------------------------------------------------

# Path to the .p12 certificate file, OR base64-encoded content prefixed with
# "data:application/x-pkcs12;base64," for CI environments.
# electron-builder also accepts WIN_CSC_LINK as an alias.
WIN_CSC_LINK=./certs/code-signing-ev.p12

# Password protecting the .p12 file
WIN_CSC_KEY_PASSWORD=your-p12-password

# Alternative: EV tokens stored on a USB HSM (e.g. SafeNet).
# Set this to "ev-token" and configure your token driver on the build machine.
# build-installer.js will skip certificate file validation in this mode.
# SPARELINK_WINDOWS_SIGNING_MODE=ev-token

# ----------------------------------------------------------------------------
# macOS Developer ID + Notarization (Apple Developer Program, $99/year)
# ----------------------------------------------------------------------------

# Path or base64 content of the Developer ID Application .p12
CSC_LINK=./certs/developer-id-application.p12
CSC_KEY_PASSWORD=your-p12-password

# Apple ID (email) used to sign in to notarization service
APPLE_ID=your-apple-id@example.com

# App-specific password — generate at https://appleid.apple.com → Sign-In & Security
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 10-character Team ID — visible at https://developer.apple.com/account → Membership
APPLE_TEAM_ID=XXXXXXXXXX

# ----------------------------------------------------------------------------
# Update Server (required for --publish flag)
# ----------------------------------------------------------------------------
SPARELINK_UPDATE_URL=https://updates.example.com/sparelink
