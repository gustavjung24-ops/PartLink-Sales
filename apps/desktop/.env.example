# ============================================================================
# Desktop Build — Code Signing Environment Variables
# Copy this file to .env (git-ignored) for local signed builds.
# In CI, set these as GitHub Actions Secrets (see .github/workflows/build-release.yml).
#
# ⚠️  SECURITY: NEVER store .p12 / .pfx / .cer files inside the repository,
#          even in a private repo. Always pass certificates as base64-encoded
#          environment variables (CSC_LINK / WIN_CSC_LINK).
# ⚠️  For local dev, point to an ABSOLUTE PATH outside the workspace, or use
#          base64 encoding (see instructions below).
# ============================================================================

# How to encode your .p12 as base64 (Linux / macOS):
#   base64 -w 0 your-cert.p12          # Linux
#   base64 -i your-cert.p12            # macOS
# Then paste the output as the value below (no newlines).

# ----------------------------------------------------------------------------
# Windows EV Code Signing (DigiCert / Sectigo / GlobalSign)
# electron-builder reads WIN_CSC_LINK and WIN_CSC_KEY_PASSWORD automatically.
# certificateFile must NOT be set in electron-builder.json — use env vars only.
# ----------------------------------------------------------------------------

# Base64-encoded .p12 EV certificate (never a file path pointing inside the repo)
WIN_CSC_LINK=data:application/x-pkcs12;base64,<BASE64_ENCODED_P12_HERE>

# Password protecting the .p12 file
WIN_CSC_KEY_PASSWORD=your-p12-password

# Alternative: EV tokens stored on a USB HSM (e.g. SafeNet).
# Set this to "ev-token" and configure your token driver on the build machine.
# build-installer.js will skip certificate env-var validation in this mode.
# SPARELINK_WINDOWS_SIGNING_MODE=ev-token

# ----------------------------------------------------------------------------
# macOS Developer ID + Notarization (Apple Developer Program, $99/year)
# Notarization uses xcrun notarytool (altool is removed since Xcode 15).
# ----------------------------------------------------------------------------

# Base64-encoded Developer ID Application .p12 (never a file path inside the repo)
CSC_LINK=data:application/x-pkcs12;base64,<BASE64_ENCODED_P12_HERE>
CSC_KEY_PASSWORD=your-p12-password

# Apple ID (email) used to sign in to notarization service
APPLE_ID=your-apple-id@example.com

# App-specific password — generate at https://appleid.apple.com → Sign-In & Security
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# 10-character Team ID — visible at https://developer.apple.com/account → Membership
APPLE_TEAM_ID=XXXXXXXXXX

# ----------------------------------------------------------------------------
# Update Server (required for --publish flag)
# ----------------------------------------------------------------------------
SPARELINK_UPDATE_URL=https://updates.example.com/sparelink
