{
  "appId": "com.partling.sale",
  "productName": "Partling-sale",
  "asar": true,
  "files": ["dist/**", "node_modules/**", "resources/**", "package.json"],
  "asarUnpack": ["**/better-sqlite3/**"],
  "extraResources": [
    { "from": "resources/", "to": "resources", "filter": ["**/*"] }
  ],
  "win": {
    "target": ["portable", "nsis"],
    "artifactName": "Partling-sale-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowElevation": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
