{
  "name": "@sparelink/desktop",
  "version": "1.0.0",
  "description": "SPARELINK Desktop Application",
  "type": "module",
  "main": "dist/main/index.cjs",
  "preload": "dist/preload/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "pnpm run build && electron-builder --config electron-builder.json",
    "build:installer": "node ../../scripts/build-installer.js",
    "build:installer:publish": "node ../../scripts/build-installer.js --publish",
    "preview": "electron-vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@sparelink/shared": "workspace:*",
    "@tanstack/query-sync-storage-persister": "^5.83.0",
    "@tanstack/react-query": "^5.28.0",
    "@tanstack/react-query-persist-client": "^5.83.0",
    "better-sqlite3": "^9.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "node-machine-id": "^1.1.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.0",
    "tailwind-merge": "^3.3.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.5.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "autoprefixer": "^10.4.21",
    "electron": "^27.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.4.19"
  }
}
