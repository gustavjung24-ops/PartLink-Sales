{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "declaration": false,
    "declarationMap": false,
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"],
       "@sparelink/shared": ["../../packages/shared/src/index.ts"],
       "@sparelink/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
