# API Configuration
PORT=3000
NODE_ENV=development

# Database - PostgreSQL
# For local development with Docker: postgresql://user:password@localhost:5432/sparelink
# For production: use managed service URL
DATABASE_URL=postgresql://sparelink:sparelink_dev@localhost:5432/sparelink_dev

# JWT & Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRY=7d

# Database Encryption (for license metadata, sensitive data)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-in-production

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Feature flags
ENABLE_AI_SUGGESTIONS=true
AI_CONFIDENCE_THRESHOLD=50
REQUIRE_APPROVAL_THRESHOLD=75
