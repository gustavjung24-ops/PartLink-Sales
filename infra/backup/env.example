BACKUP_ROOT=/var/backups/sparelink
BACKUP_RETENTION_DAYS=30
WAL_RETENTION_DAYS=7

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=sparelink_prod
DB_USER=sparelink_backup
PGPASSWORD=replace-me

# Enforce TLS for all pg_basebackup and pg_dump connections.
PGSSLMODE=require

# Optional: object storage destination for off-site copies.
S3_BACKUP_URI=s3://sparelink-backups/postgres

# Encryption at rest — SSE-KMS key ARN or alias.
# When set, all S3 uploads (base backups, WAL, logical dumps) use SSE-KMS.
# Never hard-code the key value here; use a secrets manager to inject it at runtime.
# Example: arn:aws:kms:ap-southeast-1:<ACCOUNT_ID>:key/<KEY_ID>
S3_KMS_KEY_ID=

# Backup failure alerting.
# At least one channel should be configured for production.
# Slack / Teams / PagerDuty incoming webhook URL:
BACKUP_ALERT_WEBHOOK=
# Email recipient (requires `mail` utility on the backup host):
BACKUP_ALERT_EMAIL=
# From address used for email alerts:
BACKUP_ALERT_FROM=sparelink-backup@example.com

# Required on the standby host when running restore-pitr.sh
PGDATA=/var/lib/postgresql/15/main

# Optional: point-in-time target, example 2026-03-22 14:30:00+00
RECOVERY_TARGET_TIME=

# Optional: override the generated restore command when WAL is restored from another store.
RESTORE_WAL_COMMAND=
